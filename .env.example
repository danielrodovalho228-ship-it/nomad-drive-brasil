# ============================================================
# Nomade Drive Brasil — variaveis de ambiente (EXEMPLO)
# ============================================================
# Copie este arquivo para ".env" e preencha com valores reais.
# O ".env" real NUNCA deve ser versionado (ja esta no .gitignore).
#
# IMPORTANTE — site estatico (GitHub Pages):
#   O site publico NAO le este .env. Ele usa o arquivo
#   "supabase-config.js", onde fica apenas a anon/publishable key
#   (chave publica, protegida por Row Level Security).
#
#   Este .env serve para um BACKEND seguro (Supabase Edge Functions
#   ou Vercel Serverless Functions), usado em acoes administrativas
#   sensiveis nas proximas fases do projeto.
# ============================================================

# --- Publico (pode aparecer no front-end) ---
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_anon_ou_publishable_key

# --- PRIVADO — somente backend seguro. NUNCA no front-end / GitHub ---
# A service_role ignora o RLS. Se vazar, expoe todo o banco.
# Como ela ja foi exposta antes, ROTACIONE-A no painel do Supabase
# (Project Settings > API) antes de usar em producao.
SUPABASE_SERVICE_ROLE_KEY=usar_apenas_no_backend_nunca_no_frontend
